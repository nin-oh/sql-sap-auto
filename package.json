{
  "name": "sap-query-desktop",
  "productName": "SAP Query Desktop",
  "version": "0.1.0",
  "description": "Desktop app for querying SAP (SQL Server) databases with friendly variable prompts, history, tables and charts.",
  "main": "dist-electron/main.js",
  "author": "nin-oh",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "start": "electron .",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.8.0",
    "@tanstack/react-table": "^8.20.5",
    "@uiw/react-codemirror": "^4.23.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "mssql": "^11.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.ninoh.sapquery",
    "productName": "SAP Query Desktop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "signAndEditExecutable": false
    },
    "mac": { "target": ["dmg"] },
    "linux": { "target": ["AppImage"] }
  }
}
